' PASM2 Instruction Test: Event and Polling Operations
' Tests event polling, waiting, and interrupt control instructions

CON
    _clkfreq = 20_000_000

DAT
                org     0

' ============================================================================
' Test data area
' ============================================================================

event_mask      long    0
result          long    0

' ============================================================================
' POLLATN - Poll Attention
' Polls for ATN (attention) signal from another COG
' ============================================================================

t_pollatn       pollatn             wc      ' C = ATN state

' ============================================================================
' POLLINT - Poll Interrupt
' Polls for pending interrupt
' ============================================================================

t_pollint       pollint             wc      ' C = INT pending

' ============================================================================
' POLLCT1/CT2/CT3 - Poll Counters (already in counter file)
' Included here for completeness of polling family
' ============================================================================

t_pollct1_e     pollct1             wc      ' C = CT1 expired
t_pollct2_e     pollct2             wc      ' C = CT2 expired
t_pollct3_e     pollct3             wc      ' C = CT3 expired

' ============================================================================
' POLLSE1 - Poll Streamer Event 1
' ============================================================================

t_pollse1       pollse1             wc      ' C = SE1 event

' ============================================================================
' POLLSE2 - Poll Streamer Event 2
' ============================================================================

t_pollse2       pollse2             wc      ' C = SE2 event

' ============================================================================
' POLLSE3 - Poll Streamer Event 3
' ============================================================================

t_pollse3       pollse3             wc      ' C = SE3 event

' ============================================================================
' POLLSE4 - Poll Streamer Event 4
' ============================================================================

t_pollse4       pollse4             wc      ' C = SE4 event

' ============================================================================
' POLLPAT - Poll Pattern Match
' ============================================================================

t_pollpat       pollpat             wc      ' C = pattern matched

' ============================================================================
' POLLFBW - Poll FIFO Buffer Wrap
' ============================================================================

t_pollfbw       pollfbw             wc      ' C = FIFO wrapped

' ============================================================================
' POLLXMT - Poll Transmit Ready
' ============================================================================

t_pollxmt       pollxmt             wc      ' C = TX ready

' ============================================================================
' POLLXFI - Poll Transfer In Ready
' ============================================================================

t_pollxfi       pollxfi             wc      ' C = XFI ready

' ============================================================================
' POLLXRO - Poll Transfer Out Ready
' ============================================================================

t_pollxro       pollxro             wc      ' C = XRO ready

' ============================================================================
' POLLXRL - Poll Transfer Reload
' ============================================================================

t_pollxrl       pollxrl             wc      ' C = XRL ready

' ============================================================================
' WAITATN - Wait for Attention
' ============================================================================

t_waitatn       waitatn                     ' Wait for ATN

' ============================================================================
' WAITINT - Wait for Interrupt
' ============================================================================

t_waitint       waitint                     ' Wait for INT

' ============================================================================
' WAITCT1/CT2/CT3 - Wait for Counters (already in counter file)
' ============================================================================

t_waitct1_e     waitct1                     ' Wait for CT1
t_waitct2_e     waitct2                     ' Wait for CT2
t_waitct3_e     waitct3                     ' Wait for CT3

' ============================================================================
' WAITSE1 - Wait for Streamer Event 1
' ============================================================================

t_waitse1       waitse1                     ' Wait for SE1

' ============================================================================
' WAITSE2 - Wait for Streamer Event 2
' ============================================================================

t_waitse2       waitse2                     ' Wait for SE2

' ============================================================================
' WAITSE3 - Wait for Streamer Event 3
' ============================================================================

t_waitse3       waitse3                     ' Wait for SE3

' ============================================================================
' WAITSE4 - Wait for Streamer Event 4
' ============================================================================

t_waitse4       waitse4                     ' Wait for SE4

' ============================================================================
' WAITPAT - Wait for Pattern Match
' ============================================================================

t_waitpat       waitpat                     ' Wait for pattern

' ============================================================================
' WAITFBW - Wait for FIFO Buffer Wrap
' ============================================================================

t_waitfbw       waitfbw                     ' Wait for FIFO wrap

' ============================================================================
' WAITXMT - Wait for Transmit Ready
' ============================================================================

t_waitxmt       waitxmt                     ' Wait for TX ready

' ============================================================================
' WAITXFI - Wait for Transfer In
' ============================================================================

t_waitxfi       waitxfi                     ' Wait for XFI

' ============================================================================
' WAITXRO - Wait for Transfer Out
' ============================================================================

t_waitxro       waitxro                     ' Wait for XRO

' ============================================================================
' WAITXRL - Wait for Transfer Reload
' ============================================================================

t_waitxrl       waitxrl                     ' Wait for XRL

' ============================================================================
' ALLOWI - Allow Interrupts
' ============================================================================

t_allowi        allowi                      ' Enable interrupts

' ============================================================================
' STALLI - Stall Interrupts
' ============================================================================

t_stalli        stalli                      ' Disable interrupts

' ============================================================================
' TRGINT1 - Trigger Interrupt 1
' ============================================================================

t_trgint1       trgint1                     ' Trigger INT1

' ============================================================================
' TRGINT2 - Trigger Interrupt 2
' ============================================================================

t_trgint2       trgint2                     ' Trigger INT2

' ============================================================================
' TRGINT3 - Trigger Interrupt 3
' ============================================================================

t_trgint3       trgint3                     ' Trigger INT3

' ============================================================================
' NIXINT1 - Cancel Interrupt 1
' ============================================================================

t_nixint1       nixint1                     ' Cancel INT1

' ============================================================================
' NIXINT2 - Cancel Interrupt 2
' ============================================================================

t_nixint2       nixint2                     ' Cancel INT2

' ============================================================================
' NIXINT3 - Cancel Interrupt 3
' ============================================================================

t_nixint3       nixint3                     ' Cancel INT3

' ============================================================================
' SETINT1 - Set Interrupt 1 Source
' ============================================================================

t_setint1_reg   setint1 event_mask          ' Set INT1 source from reg
t_setint1_imm   setint1 #%0001              ' Set INT1 source immediate

' ============================================================================
' SETINT2 - Set Interrupt 2 Source
' ============================================================================

t_setint2_reg   setint2 event_mask
t_setint2_imm   setint2 #%0010

' ============================================================================
' SETINT3 - Set Interrupt 3 Source
' ============================================================================

t_setint3_reg   setint3 event_mask
t_setint3_imm   setint3 #%0100

' ============================================================================
' SETQ - Set Q Register (for event operations)
' ============================================================================

t_setq_reg      setq    event_mask
t_setq_imm      setq    #0

' ============================================================================
' SETQ2 - Set Q2 Register
' ============================================================================

t_setq2_reg     setq2   event_mask
t_setq2_imm     setq2   #0

' ============================================================================
' End marker
' ============================================================================

                ret

