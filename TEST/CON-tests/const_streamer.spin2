c_x_rfbyte_8p_1dac8 long    X_RFBYTE_8P_1DAC8

' RFWORD/RFLONG DAC Modes
c_x_rfword_16p_4dac4 long   X_RFWORD_16P_4DAC4
c_x_rfword_16p_2dac8 long   X_RFWORD_16P_2DAC8
c_x_rflong_32p_4dac8 long   X_RFLONG_32P_4DAC8

' Color Modes
c_x_rfbyte_luma8    long    X_RFBYTE_LUMA8
c_x_rfbyte_rgbi8    long    X_RFBYTE_RGBI8
c_x_rfbyte_rgb8     long    X_RFBYTE_RGB8
c_x_rfword_rgb16    long    X_RFWORD_RGB16
