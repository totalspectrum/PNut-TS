' Built-in Constants Test: Streamer Constants
' Validates X_* streamer mode constants
' Each constant stored in DAT for binary comparison

CON
    _clkfreq = 20_000_000

DAT
                org     0

' LUT Mode Constants
c_x_imm_32x1_lut    long    X_IMM_32X1_LUT
c_x_imm_16x2_lut    long    X_IMM_16X2_LUT
c_x_imm_8x4_lut     long    X_IMM_8X4_LUT
c_x_imm_4x8_lut     long    X_IMM_4X8_LUT

' Immediate DAC Output Modes
c_x_imm_32x1_1dac1  long    X_IMM_32X1_1DAC1
c_x_imm_16x2_2dac1  long    X_IMM_16X2_2DAC1
c_x_imm_16x2_1dac2  long    X_IMM_16X2_1DAC2
c_x_imm_8x4_4dac1   long    X_IMM_8X4_4DAC1
c_x_imm_8x4_2dac2   long    X_IMM_8X4_2DAC2
c_x_imm_8x4_1dac4   long    X_IMM_8X4_1DAC4
c_x_imm_4x8_4dac2   long    X_IMM_4X8_4DAC2
