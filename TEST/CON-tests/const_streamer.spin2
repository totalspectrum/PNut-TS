c_x_rflong_16x2_lut long    X_RFLONG_16X2_LUT
c_x_rflong_8x4_lut  long    X_RFLONG_8X4_LUT
c_x_rflong_4x8_lut  long    X_RFLONG_4X8_LUT

' RFBYTE DAC Modes
c_x_rfbyte_1p_1dac1 long    X_RFBYTE_1P_1DAC1
c_x_rfbyte_2p_2dac1 long    X_RFBYTE_2P_2DAC1
