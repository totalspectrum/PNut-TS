' Built-in Constants Test: SmartPin Constants
' Validates P_* smart pin mode constants
' Each constant stored in DAT for binary comparison

CON
    _clkfreq = 20_000_000

DAT
                org     0

' Pin Input/Output Control
c_p_normal          long    P_NORMAL
c_p_true_in         long    P_TRUE_IN
c_p_invert_in       long    P_INVERT_IN
c_p_true_out        long    P_TRUE_OUT
c_p_invert_out      long    P_INVERT_OUT

' Pin Drive Strength - High Side
c_p_high_fast       long    P_HIGH_FAST
c_p_high_1k5        long    P_HIGH_1K5
c_p_high_15k        long    P_HIGH_15K
c_p_high_150k       long    P_HIGH_150K
c_p_high_1ma        long    P_HIGH_1MA
c_p_high_100ua      long    P_HIGH_100UA
c_p_high_10ua       long    P_HIGH_10UA
c_p_high_float      long    P_HIGH_FLOAT

' Pin Drive Strength - Low Side
c_p_low_fast        long    P_LOW_FAST
c_p_low_1k5         long    P_LOW_1K5
c_p_low_15k         long    P_LOW_15K
c_p_low_150k        long    P_LOW_150K
c_p_low_1ma         long    P_LOW_1MA
c_p_low_100ua       long    P_LOW_100UA
c_p_low_10ua        long    P_LOW_10UA
c_p_low_float       long    P_LOW_FLOAT

' Input Selection A
c_p_true_a          long    P_TRUE_A
c_p_invert_a        long    P_INVERT_A
c_p_local_a         long    P_LOCAL_A

' Input Selection B
c_p_true_b          long    P_TRUE_B
c_p_invert_b        long    P_INVERT_B
c_p_local_b         long    P_LOCAL_B

' Logic Operations
c_p_pass_ab         long    P_PASS_AB
c_p_and_ab          long    P_AND_AB
c_p_or_ab           long    P_OR_AB
c_p_xor_ab          long    P_XOR_AB

' I/O Modes
c_p_async_io        long    P_ASYNC_IO
c_p_sync_io         long    P_SYNC_IO

' Smart Pin Modes
c_p_pulse           long    P_PULSE
c_p_transition      long    P_TRANSITION
c_p_nco_freq        long    P_NCO_FREQ
c_p_nco_duty        long    P_NCO_DUTY
c_p_pwm_triangle    long    P_PWM_TRIANGLE
c_p_pwm_sawtooth    long    P_PWM_SAWTOOTH
c_p_quadrature      long    P_QUADRATURE

' Counter Modes
c_p_count_rises     long    P_COUNT_RISES
c_p_count_highs     long    P_COUNT_HIGHS
c_p_state_ticks     long    P_STATE_TICKS
c_p_high_ticks      long    P_HIGH_TICKS

' ADC Modes
c_p_adc             long    P_ADC
c_p_adc_ext         long    P_ADC_EXT
c_p_adc_scope       long    P_ADC_SCOPE
c_p_adc_gio         long    P_ADC_GIO
c_p_adc_vio         long    P_ADC_VIO
c_p_adc_float       long    P_ADC_FLOAT
c_p_adc_1x          long    P_ADC_1X
c_p_adc_3x          long    P_ADC_3X
c_p_adc_10x         long    P_ADC_10X
c_p_adc_30x         long    P_ADC_30X
c_p_adc_100x        long    P_ADC_100X

' DAC Modes
c_p_dac_990r_3v     long    P_DAC_990R_3V
c_p_dac_600r_2v     long    P_DAC_600R_2V
c_p_dac_124r_3v     long    P_DAC_124R_3V
c_p_dac_75r_2v      long    P_DAC_75R_2V
c_p_dac_noise       long    P_DAC_NOISE
c_p_dac_dither_rnd  long    P_DAC_DITHER_RND
c_p_dac_dither_pwm  long    P_DAC_DITHER_PWM

' Serial Modes
c_p_usb_pair        long    P_USB_PAIR
c_p_sync_tx         long    P_SYNC_TX
c_p_sync_rx         long    P_SYNC_RX
c_p_async_tx        long    P_ASYNC_TX
c_p_async_rx        long    P_ASYNC_RX

' Truth Table
c_p_tt_00           long    P_TT_00
c_p_tt_01           long    P_TT_01
c_p_tt_10           long    P_TT_10
c_p_tt_11           long    P_TT_11

' Other
c_p_oe              long    P_OE
c_p_channel         long    P_CHANNEL
c_p_bitdac          long    P_BITDAC

                ret

