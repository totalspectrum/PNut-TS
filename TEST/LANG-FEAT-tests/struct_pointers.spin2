{Spin2_v45}
' struct_pointers.spin2
' STRUCT pointer tests for PNut-TS regression testing
'
' Tests covered:
'   - Getting address with @
'   - Member access through address
'   - Memory access with LONG[]
'   - Pointer as parameter (address passing)
'   - Structure array addressing

CON
  _clkfreq = 200_000_000

  NUM_POINTS = 4

  STRUCT point(x, y)
  STRUCT line(point a, point b)

VAR
  point storage
  point points[NUM_POINTS]
  line myLine
  LONG result

PUB Main()

  TestAddressBasic()
  TestMemberAccess()
  TestArrayAddressing()
  TestPointerParameter(@storage)

PRI TestAddressBasic() | LONG ptr
  ' Initialize storage
  storage.x := 100
  storage.y := 200

  ' Get address of storage
  ptr := @storage

  ' Read through pointer using LONG[] access
  result := LONG[ptr][0]                ' x (100)
  result := LONG[ptr][1]                ' y (200)

  ' Write through pointer
  LONG[ptr][0] := 150                   ' x
  LONG[ptr][1] := 250                   ' y

  ' Verify storage changed
  result := storage.x                   ' 150
  result := storage.y                   ' 250

PRI TestMemberAccess() | LONG ptr
  ' Initialize line struct
  myLine.a.x := 0
  myLine.a.y := 0
  myLine.b.x := 100
  myLine.b.y := 100

  ' Get address of line
  ptr := @myLine

  ' Access nested members through LONG[] access
  ' line contains: a.x, a.y, b.x, b.y (4 LONGs = 16 bytes)
  result := LONG[ptr][0]                ' a.x (0)
  result := LONG[ptr][1]                ' a.y (0)
  result := LONG[ptr][2]                ' b.x (100)
  result := LONG[ptr][3]                ' b.y (100)

  ' Modify through pointer
  LONG[ptr][0] := 10                    ' a.x
  LONG[ptr][3] := 90                    ' b.y

  ' Verify myLine changed
  result := myLine.a.x                  ' 10
  result := myLine.b.y                  ' 90

PRI TestArrayAddressing() | i, LONG ptr
  ' Initialize array of points
  repeat i from 0 to NUM_POINTS - 1
    points[i].x := i * 10
    points[i].y := i * 20

  ' Get address of first element
  ptr := @points[0]

  ' Read first element (each point is 8 bytes = 2 LONGs)
  result := LONG[ptr][0]                ' x of points[0] = 0
  result := LONG[ptr][1]                ' y of points[0] = 0

  ' Advance to second element (add 8 bytes = 2 LONGs offset)
  ptr := @points[1]
  result := LONG[ptr][0]                ' x of points[1] = 10
  result := LONG[ptr][1]                ' y of points[1] = 20

  ' Use array address arithmetic
  ptr := @points[0]
  result := LONG[ptr + 16][0]           ' x of points[2] = 20
  result := LONG[ptr + 16][1]           ' y of points[2] = 40

  ' Get address of specific element
  ptr := @points[3]
  result := LONG[ptr][0]                ' x of points[3] = 30
  result := LONG[ptr][1]                ' y of points[3] = 60

PRI TestPointerParameter(ptrAddr)
  ' Modify struct through address parameter
  LONG[ptrAddr][0] := 999               ' x
  LONG[ptrAddr][1] := 888               ' y

  ' Read through parameter
  result := LONG[ptrAddr][0]            ' 999
  result := LONG[ptrAddr][1]            ' 888

  ' Also verify via direct access
  result := storage.x                   ' 999
  result := storage.y                   ' 888
