# Local mount configuration template
# ===================================
# Copy this file to docker-compose.override.yml and customize for your system.
# docker-compose.override.yml is gitignored and will not be committed.
#
# Usage:
#   cp docker-compose.override.yml.example docker-compose.override.yml
#   # Edit docker-compose.override.yml with your local paths
#   # Rebuild container in VS Code

version: '3.8'

services:
  dev:
    volumes:
      # Claude configuration directory
      # - /path/to/your/.claude:/home/vscode/.claude

      # Container tools (MCP servers, etc.)
      # - /path/to/your/container-tools:/opt/container-tools

      # Add any other local mounts you need:
      # - /your/local/path:/container/path
